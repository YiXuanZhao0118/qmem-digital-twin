DATABASE_URL=postgresql+asyncpg://qmem:qmem_password@localhost:5432/qmem_twin
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ASSET_ROOT=assets
ONSHAPE_ACCESS_KEY=
ONSHAPE_SECRET_KEY=
ONSHAPE_BASE_URL=https://cad.onshape.com

# AI binding agent (alembic 0057, agent_orchestrator). Leave ANTHROPIC_API_KEY
# blank to disable the orchestrator — session lifecycle still works but
# the POST /messages endpoint returns a friendly error.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

