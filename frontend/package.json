{
  "name": "qmem-digital-twin-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run export:kinds && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "export:kinds": "npx -y tsx ../scripts/export_kinds_manifest.ts"
  },
  "dependencies": {
    "@kitware/vtk.js": "^35.15.1",
    "@monaco-editor/react": "^4.7.0",
    "@vitejs/plugin-react": "^4.3.3",
    "axios": "^1.7.7",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "uplot": "^1.6.32",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.9"
  }
}
